# Medusa Environment Variables
# Copy this to .env and fill in your values

# Database
POSTGRES_DB=medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=your_secure_password_here

# Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
COOKIE_SECRET=your_cookie_secret_here

# CORS (comma-separated URLs)
# Your storefront URLs
STORE_CORS=https://your-store.com,http://localhost:8000
# Admin dashboard URL (usually same as backend)
ADMIN_CORS=https://medusajs.psmhome.no
# Auth CORS (admin + storefront)
AUTH_CORS=https://medusajs.psmhome.no,https://your-store.com

# Backend URL (public URL of your Medusa backend)
BACKEND_URL=https://medusajs.psmhome.no

# Port (default 9000)
MEDUSA_PORT=9000

# Optional: S3/MinIO File Storage
# S3_FILE_URL=https://your-bucket.s3.amazonaws.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_REGION=us-east-1
# S3_BUCKET=medusa-files
# S3_ENDPOINT=https://s3.amazonaws.com  # or MinIO endpoint

# ================================================
# INTEGRATIONS (to be configured)
# ================================================

# Razorpay Payment Gateway
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=https://medusajs.psmhome.no/auth/google/callback

# Facebook OAuth
# FACEBOOK_CLIENT_ID=your_facebook_app_id
# FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
# FACEBOOK_CALLBACK_URL=https://medusajs.psmhome.no/auth/facebook/callback

# Shiprocket Integration
# SHIPROCKET_EMAIL=your_shiprocket_email
# SHIPROCKET_PASSWORD=your_shiprocket_password
# SHIPROCKET_CHANNEL_ID=your_channel_id
